---
import { getContent } from '../i18n/content';
import { getLangFromUrl } from '../i18n/config';
const c = getContent(getLangFromUrl(Astro.url));
const e = c.events;
---

<section class="section" id="events">
  <div class="container">
    <div class="section-head" data-reveal>
      <p class="eyebrow">{e.eyebrow}</p>
      <h2 style="margin:18px 0 16px">{e.title}</h2>
      <p>{e.subtitle}</p>
    </div>

    <ul class="events-list" data-reveal>
      {
        e.items.map((item) => (
          <li class="event-row">
            <span class="event-type chip"><span class="dot" />{item.type}</span>
            <div class="event-main">
              <h3>{item.name}</h3>
              <p>{item.desc}</p>
            </div>
            <div class="event-meta">
              <span class="event-date mono">{item.date}</span>
              <span class="event-loc">{item.location}</span>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .events-list {
    border-top: 1px solid var(--border);
  }
  .event-row {
    display: grid;
    grid-template-columns: 180px 1fr auto;
    gap: 28px;
    align-items: center;
    padding: 26px 8px;
    border-bottom: 1px solid var(--border);
    transition: background 0.25s var(--ease), padding 0.25s var(--ease);
  }
  .event-row:hover {
    background: var(--surface);
    padding-inline: 20px;
  }
  .event-type {
    justify-self: start;
  }
  .event-main h3 {
    font-size: 1.2rem;
    margin-bottom: 6px;
  }
  .event-main p {
    font-size: 0.92rem;
    max-width: 56ch;
  }
  .event-meta {
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .event-date {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--red-300);
  }
  .event-loc {
    font-size: 0.82rem;
    color: var(--text-dim);
  }
  @media (max-width: 820px) {
    .event-row {
      grid-template-columns: 1fr;
      gap: 12px;
      align-items: start;
    }
    .event-meta {
      text-align: left;
      flex-direction: row;
      gap: 14px;
      align-items: baseline;
    }
  }
</style>
