---
import { getContent } from '../i18n/content';
import { getLangFromUrl } from '../i18n/config';
const c = getContent(getLangFromUrl(Astro.url));

// Geometric line icons, index-aligned with offer.items
const icons = [
  '<path d="M12 2l9 5v10l-9 5-9-5V7z"/><path d="M12 7v10M7.5 9.5l9 5M16.5 9.5l-9 5"/>', // capital / crystal
  '<path d="M8 6l-5 6 5 6M16 6l5 6-5 6"/><path d="M13 4l-2 16"/>', // engineering / code
  '<circle cx="9" cy="8" r="3"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6"/><path d="M16 4a3 3 0 010 6M21 20c0-2.5-1.3-4.6-3.3-5.5"/>', // mentorship
  '<circle cx="5" cy="6" r="2"/><circle cx="19" cy="6" r="2"/><circle cx="12" cy="19" r="2"/><path d="M6.6 7.5l4 9.5M17.4 7.5l-4 9.5M7 6h10"/>', // network
  '<path d="M5 19c7-1 13-7 14-14"/><path d="M14 5h5v5"/><path d="M5 19l3-3"/>', // go-to-market / growth
  '<path d="M4 20V10M10 20V4M16 20v-7M22 20H2"/>', // listing / liquidity
];
---

<section class="section" id="offer">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow" data-reveal>{c.offer.eyebrow}</p>
      <h2 data-reveal style="--reveal-delay:60ms">{c.offer.title}</h2>
      <p data-reveal style="--reveal-delay:120ms">{c.offer.subtitle}</p>
    </div>

    <div class="offer-grid">
      {
        c.offer.items.map((item, i) => (
          <article class="card offer-item" data-reveal style={`--reveal-delay:${(i % 3) * 90}ms`}>
            <span class="offer-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icons[i]} />
            </span>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .offer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .offer-item {
    padding: 32px;
  }
  .offer-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 54px;
    height: 54px;
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(255, 36, 36, 0.12), rgba(255, 36, 36, 0.03));
    border: 1px solid var(--border-red);
    color: var(--red-400);
    margin-bottom: 22px;
  }
  .offer-icon svg {
    width: 26px;
    height: 26px;
  }
  .offer-item h3 {
    font-size: 1.25rem;
    margin-bottom: 10px;
  }
  .offer-item p {
    font-size: 0.96rem;
  }
  @media (max-width: 920px) {
    .offer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .offer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
