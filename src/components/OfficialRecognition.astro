---
import EOSMark from './EOSMark.astro';
import BrandMark from './BrandMark.astro';
import { getContent } from '../i18n/content';
import { getLangFromUrl } from '../i18n/config';
const c = getContent(getLangFromUrl(Astro.url));
const r = c.recognition;
---

<section class="section recog-section" id="recognition">
  <div class="container">
    <div class="recog card" data-reveal>
      <div class="recog-lockup">
        <!-- OMEGA brand (red) × EOS official (neutral) co-lockup -->
        <span class="lk lk-omega"><BrandMark size={52} id="recog" /></span>
        <span class="lk-x" aria-hidden="true">×</span>
        <span class="lk lk-eos"><EOSMark size={58} /></span>
      </div>
      <div class="recog-body">
        <span class="chip"><span class="dot"></span>{r.badge}</span>
        <h2>{r.title}</h2>
        <p class="lead">{r.statement}</p>
      </div>
    </div>
    <p class="recog-note mono">{r.note}</p>
  </div>
</section>

<style>
  .recog-section {
    padding-block: clamp(40px, 6vw, 72px);
  }
  .recog {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 48px;
    align-items: center;
    padding: 44px 48px;
    border-color: var(--border-red);
    background: linear-gradient(120deg, rgba(255, 36, 36, 0.07), var(--surface) 60%);
  }
  .recog-lockup {
    display: flex;
    align-items: center;
    gap: 20px;
    padding-right: 48px;
    border-right: 1px solid var(--border-strong);
  }
  .lk {
    display: grid;
    place-items: center;
  }
  .lk-x {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--text-dim);
  }
  .recog-body .chip {
    margin-bottom: 16px;
  }
  .recog-body h2 {
    font-size: clamp(1.4rem, 2.4vw, 1.9rem);
    margin-bottom: 12px;
  }
  .recog-body p {
    max-width: 64ch;
  }
  .recog-note {
    margin-top: 16px;
    font-size: 0.72rem;
    color: var(--text-dim);
    text-align: center;
  }
  @media (max-width: 760px) {
    .recog {
      grid-template-columns: 1fr;
      gap: 28px;
      padding: 32px;
      text-align: center;
    }
    .recog-lockup {
      justify-content: center;
      padding-right: 0;
      padding-bottom: 28px;
      border-right: none;
      border-bottom: 1px solid var(--border-strong);
    }
    .recog-body .chip {
      justify-content: center;
    }
  }
</style>
