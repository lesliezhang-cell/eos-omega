---
import Logo from './Logo.astro';
import { getContent } from '../i18n/content';
import { getLangFromUrl, localizePath, switchLangPath } from '../i18n/config';

const url = Astro.url;
const lang = getLangFromUrl(url);
const c = getContent(lang);
const home = localizePath('/', lang);

const navLinks = [
  { label: c.nav.about, href: localizePath('/about', lang) },
  { label: c.nav.programs, href: localizePath('/programs', lang) },
  { label: c.nav.portfolio, href: localizePath('/portfolio', lang) },
  { label: c.nav.ecosystem, href: localizePath('/ecosystem', lang) },
  { label: c.nav.process, href: `${home === '/' ? '' : home}/#process` },
];

const enPath = switchLangPath(url, 'en');
const zhPath = switchLangPath(url, 'zh');
const applyHref = localizePath('/apply', lang);
---

<header class="site-header" id="site-header">
  <div class="container header-inner">
    <a href={home} class="header-logo" aria-label="EOS OMEGA — home">
      <Logo size={36} id="hdr" />
    </a>

    <nav class="nav-desktop" aria-label="Primary">
      {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="header-right">
      <div class="lang-switch" role="group" aria-label="Language">
        <a href={enPath} class:list={['lang', lang === 'en' && 'active']}>EN</a>
        <span class="lang-sep">/</span>
        <a href={zhPath} class:list={['lang', lang === 'zh' && 'active']}>中文</a>
      </div>
      <a href={applyHref} class="btn btn-primary apply-cta">{c.actions.apply}</a>
      <button class="menu-btn" id="menu-btn" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile panel -->
  <div class="mobile-panel" id="mobile-panel" hidden>
    <nav aria-label="Mobile">
      {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
      <a href={applyHref} class="btn btn-primary">{c.actions.apply}</a>
      <div class="mobile-lang">
        <a href={enPath} class:list={[lang === 'en' && 'active']}>EN</a>
        <a href={zhPath} class:list={[lang === 'zh' && 'active']}>中文</a>
      </div>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-h);
    display: flex;
    align-items: center;
    transition: background 0.3s var(--ease), border-color 0.3s var(--ease), backdrop-filter 0.3s;
    border-bottom: 1px solid transparent;
  }
  .site-header.scrolled {
    background: rgba(8, 5, 6, 0.72);
    backdrop-filter: blur(14px) saturate(140%);
    border-bottom-color: var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    width: 100%;
  }
  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 34px;
    margin-left: auto;
  }
  .nav-desktop a {
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.2s;
    position: relative;
  }
  .nav-desktop a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -6px;
    width: 0;
    height: 1px;
    background: var(--red-500);
    box-shadow: var(--glow-sm);
    transition: width 0.25s var(--ease);
  }
  .nav-desktop a:hover {
    color: var(--text);
  }
  .nav-desktop a:hover::after {
    width: 100%;
  }
  .header-right {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .lang-switch {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .lang-switch .lang {
    color: var(--text-dim);
    transition: color 0.2s;
  }
  .lang-switch .lang.active {
    color: var(--red-400);
  }
  .lang-switch .lang:hover {
    color: var(--text);
  }
  .lang-sep {
    color: var(--border-strong);
  }
  .menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
  }
  .menu-btn span {
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.3s var(--ease), opacity 0.2s;
  }
  .menu-btn[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .menu-btn[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .menu-btn[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-panel {
    position: fixed;
    top: var(--nav-h);
    left: 0;
    right: 0;
    background: rgba(8, 5, 6, 0.97);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    padding: 24px;
  }
  .mobile-panel nav {
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-width: var(--maxw);
    margin-inline: auto;
  }
  .mobile-panel nav a {
    padding: 14px 4px;
    font-size: 1.05rem;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }
  .mobile-panel .btn {
    margin-top: 16px;
    justify-content: center;
  }
  .mobile-lang {
    display: flex;
    gap: 20px;
    margin-top: 18px;
    font-family: var(--font-mono);
  }
  .mobile-lang a {
    color: var(--text-dim);
    border: none !important;
    padding: 0 !important;
  }
  .mobile-lang a.active {
    color: var(--red-400);
  }

  @media (max-width: 880px) {
    .nav-desktop,
    .apply-cta,
    .lang-switch {
      display: none;
    }
    .menu-btn {
      display: flex;
    }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const onScroll = () => header?.classList.toggle('scrolled', window.scrollY > 12);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const btn = document.getElementById('menu-btn');
  const panel = document.getElementById('mobile-panel');
  btn?.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    if (panel) panel.hidden = open;
  });
</script>
