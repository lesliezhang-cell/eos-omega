---
import { getContent } from '../i18n/content';
import { getLangFromUrl } from '../i18n/config';
const c = getContent(getLangFromUrl(Astro.url));
---

<div class="trustbar">
  <div class="container">
    <p class="trustbar-label">{c.trust.label}</p>
    <div class="trustbar-logos" data-reveal>
      {c.trust.partners.map((p) => <span class="partner">{p}</span>)}
    </div>
  </div>
</div>

<style>
  .trustbar {
    padding-block: 40px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: rgba(255, 245, 245, 0.012);
  }
  .trustbar-label {
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 26px;
  }
  .trustbar-logos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 18px 48px;
  }
  .partner {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: 0.01em;
    color: var(--text-muted);
    opacity: 0.7;
    transition: opacity 0.25s, color 0.25s;
    cursor: default;
  }
  .partner:hover {
    opacity: 1;
    color: var(--text);
  }
  @media (max-width: 640px) {
    .trustbar-logos {
      gap: 14px 28px;
    }
    .partner {
      font-size: 0.92rem;
    }
  }
</style>
