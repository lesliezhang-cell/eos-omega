---
/**
 * EOS OMEGA brandmark — vector recreation of the official logo
 * (Ω ring + EOS crystal). Master: reference/brand/mark.svg → public/brand-mark.svg.
 * Crisp at any size; logo-original.jpeg is the visual reference.
 */
interface Props {
  size?: number;
  glow?: boolean; // kept for API compatibility; the artwork carries its own glow
  class?: string;
  id?: string;
}
const { size = 48, class: klass = '' } = Astro.props;
const src = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/brand-mark.svg`;
---

<img
  src={src}
  width={size}
  height={size}
  alt="EOS OMEGA"
  class:list={['brandmark', klass]}
  decoding="async"
  draggable="false"
/>

<style>
  .brandmark {
    display: block;
    object-fit: contain;
    user-select: none;
  }
</style>
