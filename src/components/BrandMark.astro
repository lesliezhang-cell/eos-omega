---
/**
 * EOS OMEGA brandmark — the official artwork itself, professionally keyed
 * (soft matte + white un-blend, reflections preserved) from
 * reference/brand/logo-original.jpeg via reference/brand/process_logo.py.
 */
interface Props {
  size?: number;
  glow?: boolean; // kept for API compatibility; the artwork carries its own glow
  class?: string;
  id?: string;
}
const { size = 48, class: klass = '' } = Astro.props;
const src = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/brand-mark.webp`;
---

<img
  src={src}
  width={size}
  height={size}
  alt="EOS OMEGA"
  class:list={['brandmark', klass]}
  decoding="async"
  draggable="false"
/>

<style>
  .brandmark {
    display: block;
    object-fit: contain;
    user-select: none;
  }
</style>
