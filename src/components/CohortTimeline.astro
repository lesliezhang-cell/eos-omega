---
import { getContent } from '../i18n/content';
import { getLangFromUrl, localizePath } from '../i18n/config';
const lang = getLangFromUrl(Astro.url);
const c = getContent(lang);
const co = c.cohort;
const applyHref = localizePath('/apply', lang);

interface Props {
  showCta?: boolean;
}
const { showCta = true } = Astro.props;
---

<section class="section cohort-section" id="cohort">
  <div class="container">
    <div class="cohort-box card" data-reveal>
      <div class="cohort-head">
        <p class="eyebrow">{co.eyebrow}</p>
        <h2>{co.title}</h2>
        <p class="lead">{co.subtitle}</p>
        {showCta && <a href={applyHref} class="btn btn-primary cohort-cta">{c.actions.applyNow}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>}
      </div>
      <div class="cohort-count" data-deadline="2026-08-16T00:00:00Z">
        <span class="cc-dot" aria-hidden="true"></span>
        <span class="cc-label mono">{lang === 'zh' ? '距申请截止' : 'Applications close in'}</span>
        <span class="cc-value mono js-cc">—</span>
      </div>

      <ol class="cohort-timeline">
        <span class="ct-line" aria-hidden="true"></span>
        {
          co.milestones.map((m, i) => (
            <li class="ct-item">
              <span class="ct-node"><span class="ct-num mono">{i + 1}</span></span>
              <span class="ct-date mono">{m.date}</span>
              <span class="ct-phase">{m.phase}</span>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .cohort-section {
    padding-block: clamp(40px, 6vw, 70px);
  }
  .cohort-box {
    padding: 44px 48px;
    border-color: var(--border);
    background: var(--surface-2);
  }
  .cohort-head {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 24px;
    margin-bottom: 40px;
  }
  .cohort-head .eyebrow {
    margin-bottom: 14px;
  }
  .cohort-head h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin-bottom: 12px;
  }
  .cohort-head .lead {
    max-width: 52ch;
  }
  .cohort-cta {
    white-space: nowrap;
  }
  /* Live countdown readout */
  .cohort-count {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 36px;
    padding: 11px 16px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-1);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }
  .cc-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #55d187;
    animation: ccPulse 2s ease-out infinite;
  }
  @keyframes ccPulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(85, 209, 135, 0.35);
    }
    50% {
      box-shadow: 0 0 0 5px rgba(85, 209, 135, 0);
    }
  }
  .cc-label {
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .cc-value {
    font-size: 0.98rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
  }
  .cohort-timeline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    position: relative;
  }
  .ct-line {
    position: absolute;
    top: 17px;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--red-700), var(--border-red), transparent);
  }
  .ct-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    position: relative;
  }
  .ct-node {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--bg-2);
    border: 1px solid var(--border-red);
    box-shadow: var(--glow-sm);
    margin-bottom: 8px;
  }
  .ct-num {
    font-size: 0.8rem;
    color: var(--red-400);
  }
  .ct-date {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text);
  }
  .ct-phase {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  @media (max-width: 820px) {
    .cohort-box {
      padding: 32px;
    }
    .cohort-head {
      grid-template-columns: 1fr;
      align-items: start;
    }
    .cohort-timeline {
      grid-template-columns: 1fr 1fr;
      gap: 28px 18px;
    }
    .ct-line {
      display: none;
    }
  }
</style>

<script>
  function initCohortCountdown() {
    const boxes = document.querySelectorAll<HTMLElement>('.cohort-count');
    if (!boxes.length) return;
    const update = () => {
      const now = Date.now();
      boxes.forEach((box) => {
        const deadline = Date.parse(box.dataset.deadline || '');
        const out = box.querySelector('.js-cc');
        if (!out || Number.isNaN(deadline)) return;
        let s = Math.max(0, Math.floor((deadline - now) / 1000));
        const d = Math.floor(s / 86400);
        s -= d * 86400;
        const h = Math.floor(s / 3600);
        s -= h * 3600;
        const m = Math.floor(s / 60);
        const sec = s - m * 60;
        out.textContent = `${d}d ${String(h).padStart(2, '0')}h ${String(m).padStart(2, '0')}m ${String(sec).padStart(2, '0')}s`;
      });
    };
    update();
    if ((window as any).__ccTimer) clearInterval((window as any).__ccTimer);
    (window as any).__ccTimer = setInterval(update, 1000);
  }
  initCohortCountdown();
  document.addEventListener('astro:page-load', initCohortCountdown);
</script>
