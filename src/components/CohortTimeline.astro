---
import { getContent } from '../i18n/content';
import { getLangFromUrl, localizePath } from '../i18n/config';
const lang = getLangFromUrl(Astro.url);
const c = getContent(lang);
const co = c.cohort;
const applyHref = localizePath('/apply', lang);

interface Props {
  showCta?: boolean;
}
const { showCta = true } = Astro.props;
---

<section class="section cohort-section" id="cohort">
  <div class="container">
    <div class="cohort-box card" data-reveal>
      <div class="cohort-head">
        <p class="eyebrow">{co.eyebrow}</p>
        <h2>{co.title}</h2>
        <p class="lead">{co.subtitle}</p>
        {showCta && <a href={applyHref} class="btn btn-primary cohort-cta">{c.actions.applyNow}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>}
      </div>
      <ol class="cohort-timeline">
        <span class="ct-line" aria-hidden="true"></span>
        {
          co.milestones.map((m, i) => (
            <li class="ct-item">
              <span class="ct-node"><span class="ct-num mono">{i + 1}</span></span>
              <span class="ct-date mono">{m.date}</span>
              <span class="ct-phase">{m.phase}</span>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .cohort-section {
    padding-block: clamp(40px, 6vw, 70px);
  }
  .cohort-box {
    padding: 44px 48px;
    border-color: var(--border-red);
    background: linear-gradient(180deg, rgba(255, 36, 36, 0.06), var(--surface));
  }
  .cohort-head {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 24px;
    margin-bottom: 40px;
  }
  .cohort-head .eyebrow {
    margin-bottom: 14px;
  }
  .cohort-head h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin-bottom: 12px;
  }
  .cohort-head .lead {
    max-width: 52ch;
  }
  .cohort-cta {
    white-space: nowrap;
  }
  .cohort-timeline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    position: relative;
  }
  .ct-line {
    position: absolute;
    top: 17px;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--red-700), var(--border-red), transparent);
  }
  .ct-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    position: relative;
  }
  .ct-node {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--bg-2);
    border: 1px solid var(--border-red);
    box-shadow: var(--glow-sm);
    margin-bottom: 8px;
  }
  .ct-num {
    font-size: 0.8rem;
    color: var(--red-400);
  }
  .ct-date {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text);
  }
  .ct-phase {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  @media (max-width: 820px) {
    .cohort-box {
      padding: 32px;
    }
    .cohort-head {
      grid-template-columns: 1fr;
      align-items: start;
    }
    .cohort-timeline {
      grid-template-columns: 1fr 1fr;
      gap: 28px 18px;
    }
    .ct-line {
      display: none;
    }
  }
</style>
