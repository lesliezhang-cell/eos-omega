---
/**
 * Placeholder for the OFFICIAL EOS / Vaulta partner lockup (hexagon + wordmark).
 * Neutral (not brand-red) so it reads as an external endorsement mark.
 * Swap with the official partner asset once issued by the EOS/Vaulta foundation.
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 64, class: klass = '' } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 100 100"
  fill="none"
  class:list={['eos-mark', klass]}
  role="img"
  aria-label="EOS"
  xmlns="http://www.w3.org/2000/svg"
>
  <path
    d="M50 6 L88.1 28 L88.1 72 L50 94 L11.9 72 L11.9 28 Z"
    stroke="currentColor"
    stroke-width="3.5"
    stroke-linejoin="round"
    opacity="0.95"
  />
  <text
    x="50"
    y="50"
    text-anchor="middle"
    dominant-baseline="central"
    font-family="Sora, sans-serif"
    font-weight="800"
    font-size="22"
    letter-spacing="1"
    fill="currentColor">EOS</text>
</svg>

<style>
  .eos-mark {
    color: var(--text);
  }
</style>
