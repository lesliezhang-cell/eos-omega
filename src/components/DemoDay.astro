---
import { getContent } from '../i18n/content';
import { getLangFromUrl } from '../i18n/config';
const c = getContent(getLangFromUrl(Astro.url));
const d = c.demoDay;
---

<section class="section demoday-section" id="demoday">
  <div class="container">
    <div class="demoday card" data-reveal>
        <div class="dd-head">
        <p class="eyebrow">{d.eyebrow}</p>
        <h2>{d.title}</h2>
        <p class="lead">{d.subtitle}</p>
        <ul class="dd-points">
          {
            d.points.map((p) => (
              <li>
                <span class="dd-dot" aria-hidden="true"></span>
                {p}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="dd-stats">
        {
          d.stats.map((s) => (
            <div class="dd-stat">
              <span class="dd-stat-val glow-text">{s.value}</span>
              <span class="dd-stat-label">{s.label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .demoday {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1.3fr 0.9fr;
    gap: 56px;
    align-items: center;
    padding: clamp(40px, 6vw, 64px);
    border-color: var(--border);
    background: var(--surface-2);
  }
  .dd-head {
    position: relative;
  }
  .dd-head .eyebrow {
    margin-bottom: 16px;
  }
  .dd-head h2 {
    font-size: clamp(1.8rem, 3.4vw, 2.6rem);
    margin-bottom: 16px;
  }
  .dd-head .lead {
    max-width: 56ch;
    margin-bottom: 26px;
  }
  .dd-points {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .dd-points li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.96rem;
    color: var(--text);
  }
  .dd-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--red-500);
    box-shadow: var(--glow-sm);
    flex-shrink: 0;
  }
  .dd-stats {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 28px;
    padding-left: 48px;
    border-left: 1px solid var(--border-strong);
  }
  .dd-stat-val {
    display: block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2rem, 3.6vw, 2.8rem);
    line-height: 1;
    color: var(--text);
  }
  .dd-stat-label {
    display: block;
    margin-top: 8px;
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  @media (max-width: 860px) {
    .demoday {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .dd-stats {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 24px 36px;
      padding-left: 0;
      padding-top: 32px;
      border-left: none;
      border-top: 1px solid var(--border-strong);
    }
  }
  @media (max-width: 480px) {
    .dd-stats {
      flex-direction: column;
    }
  }
</style>
