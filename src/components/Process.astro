---
import { getContent } from '../i18n/content';
import { getLangFromUrl } from '../i18n/config';
const c = getContent(getLangFromUrl(Astro.url));
---

<section class="section process-section" id="process">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow" data-reveal>{c.process.eyebrow}</p>
      <h2 data-reveal style="--reveal-delay:60ms">{c.process.title}</h2>
    </div>

    <ol class="process-track">
      <span class="process-line" aria-hidden="true"></span>
      {
        c.process.steps.map((s, i) => (
          <li class="process-step" data-reveal style={`--reveal-delay:${i * 90}ms`}>
            <span class="process-node">
              <span class="node-num mono">{i + 1}</span>
            </span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .process-track {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
    position: relative;
  }
  .process-line {
    position: absolute;
    top: 24px;
    left: 8%;
    right: 8%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-red), var(--red-700), var(--border-red), transparent);
  }
  .process-step {
    text-align: center;
    position: relative;
  }
  .process-node {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    margin: 0 auto 20px;
    border-radius: 50%;
    background: var(--bg-2);
    border: 1px solid var(--border-red);
    box-shadow: var(--glow-sm);
    position: relative;
    z-index: 1;
  }
  .node-num {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--red-400);
  }
  .process-step h3 {
    font-size: 1.12rem;
    margin-bottom: 8px;
  }
  .process-step p {
    font-size: 0.9rem;
    max-width: 22ch;
    margin-inline: auto;
  }
  @media (max-width: 820px) {
    .process-track {
      grid-template-columns: 1fr;
      gap: 0;
      max-width: 440px;
      margin-inline: auto;
    }
    .process-line {
      top: 0;
      bottom: 24px;
      left: 24px;
      right: auto;
      width: 1px;
      height: auto;
      background: linear-gradient(180deg, transparent, var(--red-700), transparent);
    }
    .process-step {
      display: grid;
      grid-template-columns: 48px 1fr;
      gap: 18px;
      text-align: left;
      padding-bottom: 30px;
    }
    .process-node {
      margin: 0;
    }
    .process-step p {
      margin-inline: 0;
      max-width: none;
    }
  }
</style>
