---
import { getContent } from '../i18n/content';
import { getLangFromUrl } from '../i18n/config';
const c = getContent(getLangFromUrl(Astro.url));
const g = c.grants;
---

<section class="section" id="grants">
  <div class="container">
    <div class="section-head" data-reveal>
      <p class="eyebrow">{g.eyebrow}</p>
      <h2 style="margin:18px 0 16px">{g.title}</h2>
      <p>{g.subtitle}</p>
    </div>

    <div class="grants-grid">
      {
        g.items.map((item, i) => (
          <article class="card grant" data-reveal style={`--reveal-delay:${i * 90}ms`}>
            <div class="grant-top">
              <h3>{item.name}</h3>
              <span class="grant-amount mono">{item.amount}</span>
            </div>
            <p>{item.desc}</p>
          </article>
        ))
      }
    </div>

    <ul class="grant-points" data-reveal>
      {
        g.points.map((p) => (
          <li>
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8.5l3.2 3.2L13 5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {p}
          </li>
        ))
      }
    </ul>
    <p class="grant-note mono">{g.note}</p>
  </div>
</section>

<style>
  .grants-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 32px;
  }
  .grant {
    padding: 32px;
  }
  .grant-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }
  .grant-top h3 {
    font-size: 1.3rem;
  }
  .grant-amount {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--red-300);
    white-space: nowrap;
  }
  .grant p {
    font-size: 0.96rem;
  }
  .grant-points {
    display: flex;
    flex-wrap: wrap;
    gap: 14px 32px;
    padding: 22px 26px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
  }
  .grant-points li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.94rem;
    color: var(--text);
  }
  .grant-points svg {
    width: 16px;
    height: 16px;
    color: var(--red-400);
    flex-shrink: 0;
  }
  .grant-note {
    margin-top: 16px;
    font-size: 0.72rem;
    color: var(--text-dim);
  }
  @media (max-width: 900px) {
    .grants-grid {
      grid-template-columns: 1fr;
      max-width: 460px;
      margin-inline: auto;
    }
  }
</style>
