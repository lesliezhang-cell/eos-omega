---
import { getContent } from '../i18n/content';
import { getLangFromUrl } from '../i18n/config';
const c = getContent(getLangFromUrl(Astro.url));
---

<section class="section" id="faq">
  <div class="container">
    <div class="faq-layout">
      <div class="faq-head">
        <p class="eyebrow" data-reveal>{c.faq.eyebrow}</p>
        <h2 data-reveal style="--reveal-delay:60ms">{c.faq.title}</h2>
      </div>

      <div class="faq-list" data-reveal>
        {
          c.faq.items.map((item) => (
            <details class="faq-item">
              <summary>
                <span>{item.q}</span>
                <span class="faq-icon" aria-hidden="true" />
              </summary>
              <div class="faq-answer">
                <p>{item.a}</p>
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .faq-layout {
    display: grid;
    grid-template-columns: 0.7fr 1.3fr;
    gap: 48px;
    align-items: start;
  }
  .faq-item {
    border-bottom: 1px solid var(--border);
  }
  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 24px 0;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.08rem;
    color: var(--text);
    transition: color 0.2s;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item summary:hover {
    color: var(--red-300);
  }
  .faq-icon {
    position: relative;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  .faq-icon::before,
  .faq-icon::after {
    content: '';
    position: absolute;
    background: var(--red-400);
    transition: transform 0.3s var(--ease), opacity 0.3s;
  }
  .faq-icon::before {
    top: 7px;
    left: 0;
    width: 16px;
    height: 2px;
  }
  .faq-icon::after {
    top: 0;
    left: 7px;
    width: 2px;
    height: 16px;
  }
  .faq-item[open] .faq-icon::after {
    transform: scaleY(0);
    opacity: 0;
  }
  .faq-answer {
    padding-bottom: 24px;
    max-width: 60ch;
  }
  .faq-answer p {
    font-size: 0.98rem;
    line-height: 1.65;
  }
  @media (max-width: 820px) {
    .faq-layout {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
