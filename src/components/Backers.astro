---
import { getContent } from '../i18n/content';
import { getLangFromUrl } from '../i18n/config';
const c = getContent(getLangFromUrl(Astro.url));
const b = c.backers;
---

<section class="section backers-section" id="backers">
  <div class="container">
    <div class="backers-block" data-reveal>
      <p class="backers-label mono">{b.vcLabel}</p>
      <div class="backers-row">
        {b.vcs.map((v) => <span class="backer vc">{v}</span>)}
      </div>
    </div>

    <div class="backers-block media" data-reveal>
      <p class="backers-label mono">{b.mediaLabel}</p>
      <div class="backers-row">
        {b.media.map((m) => <span class="backer">{m}</span>)}
      </div>
    </div>
  </div>
</section>

<style>
  .backers-section {
    padding-block: clamp(48px, 7vw, 80px);
  }
  .backers-block {
    text-align: center;
  }
  .backers-block.media {
    margin-top: 48px;
    padding-top: 44px;
    border-top: 1px solid var(--border);
  }
  .backers-label {
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 26px;
  }
  .backers-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 16px 40px;
  }
  .backer {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--text-muted);
    opacity: 0.72;
    transition: opacity 0.25s, color 0.25s;
    cursor: default;
  }
  .backer.vc {
    font-size: 1.3rem;
  }
  .backer:hover {
    opacity: 1;
    color: var(--text);
  }
  @media (max-width: 640px) {
    .backers-row {
      gap: 14px 26px;
    }
    .backer,
    .backer.vc {
      font-size: 1.02rem;
    }
  }
</style>
