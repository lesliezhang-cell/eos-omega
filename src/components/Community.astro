---
import { getContent } from '../i18n/content';
import { getLangFromUrl } from '../i18n/config';
const c = getContent(getLangFromUrl(Astro.url));
const m = c.community;
---

<section class="section" id="community">
  <div class="container">
    <div class="community card" data-reveal>
      <div class="cm-head">
        <p class="eyebrow">{m.eyebrow}</p>
        <h2>{m.title}</h2>
        <p class="lead">{m.subtitle}</p>
        <div class="cm-stats">
          {
            m.stats.map((s) => (
              <div class="cm-stat">
                <span class="cm-stat-val glow-text">{s.value}</span>
                <span class="cm-stat-label">{s.label}</span>
              </div>
            ))
          }
        </div>
      </div>
      <div class="cm-channels">
        {
          m.channels.map((ch) => (
            <a class="cm-channel" href={ch.href} target="_blank" rel="noopener">
              <span class="cm-channel-name">{ch.name}</span>
              <span class="cm-channel-handle">{ch.handle}</span>
              <span class="cm-channel-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H9M17 7v8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          ))
        }
      </div>
    </div>
    <p class="cm-note mono">{m.note}</p>
  </div>
</section>

<style>
  .community {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 48px;
    align-items: center;
    padding: clamp(40px, 6vw, 60px);
    border-color: var(--border);
    background: var(--surface-2);
  }
  .cm-head {
    position: relative;
  }
  .cm-head .eyebrow {
    margin-bottom: 16px;
  }
  .cm-head h2 {
    font-size: clamp(1.7rem, 3vw, 2.3rem);
    margin-bottom: 14px;
  }
  .cm-head .lead {
    margin-bottom: 28px;
    max-width: 52ch;
  }
  .cm-stats {
    display: flex;
    gap: 36px;
    flex-wrap: wrap;
  }
  .cm-stat-val {
    display: block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.6rem, 2.8vw, 2.1rem);
    line-height: 1;
    color: var(--text);
  }
  .cm-stat-label {
    display: block;
    margin-top: 8px;
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .cm-channels {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .cm-channel {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 18px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-1);
    transition: border-color 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .cm-channel:hover {
    border-color: var(--border-red);
    transform: translateY(-2px);
  }
  .cm-channel-name {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--text);
  }
  .cm-channel-handle {
    font-size: 0.82rem;
    color: var(--text-dim);
  }
  .cm-channel-arrow {
    position: absolute;
    top: 16px;
    right: 16px;
    color: var(--text-dim);
    transition: color 0.25s;
  }
  .cm-channel-arrow svg {
    width: 16px;
    height: 16px;
  }
  .cm-channel:hover .cm-channel-arrow {
    color: var(--red-400);
  }
  .cm-note {
    margin-top: 14px;
    font-size: 0.72rem;
    color: var(--text-dim);
  }
  @media (max-width: 860px) {
    .community {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
