---
import BrandMark from './BrandMark.astro';
import { getContent } from '../i18n/content';
import { getLangFromUrl, localizePath } from '../i18n/config';

const lang = getLangFromUrl(Astro.url);
const c = getContent(lang);
const applyHref = localizePath('/apply', lang);
const programsHref = localizePath('/programs', lang);
---

<section class="hero">
  <div class="hero-mark" aria-hidden="true">
    <BrandMark size={620} glow={false} id="hero-bg" />
  </div>

  <div class="container hero-inner">
    <div class="hero-badge" data-reveal>
      <span class="badge-mark"><BrandMark size={20} id="hero-badge" /></span>
      <span>{c.hero.badge}</span>
    </div>

    <h1 data-reveal style="--reveal-delay:80ms">
      {c.hero.titleLead}
      <span class="hi glow-text">{c.hero.titleHi}</span>
      {c.hero.titleTail}
    </h1>

    <p class="lead hero-sub" data-reveal style="--reveal-delay:160ms">{c.hero.subtitle}</p>

    <div class="hero-cta" data-reveal style="--reveal-delay:240ms">
      <a href={applyHref} class="btn btn-primary btn-lg">
        {c.hero.ctaPrimary}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href={programsHref} class="btn btn-ghost btn-lg">{c.hero.ctaSecondary}</a>
    </div>
  </div>

  <a href="#stats" class="hero-scroll" aria-label={c.hero.scroll}>
    <span>{c.hero.scroll}</span>
    <span class="scroll-line"></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-h);
    overflow: hidden;
  }
  .hero-mark {
    position: absolute;
    top: 46%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.04;
    pointer-events: none;
    z-index: 0;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 920px;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 7px 15px 7px 7px;
    border: 1px solid var(--border-strong);
    border-radius: 100px;
    background: var(--surface);
    font-size: 0.85rem;
    color: var(--text);
    margin-bottom: 30px;
  }
  .badge-mark {
    display: inline-flex;
  }
  h1 {
    max-width: 16ch;
  }
  h1 .hi {
    color: var(--red-500);
  }
  .hero-sub {
    margin-top: 28px;
    max-width: 60ch;
  }
  .hero-cta {
    margin-top: 40px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .hero-scroll {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-dim);
    z-index: 1;
  }
  .scroll-line {
    width: 1px;
    height: 42px;
    background: linear-gradient(var(--red-500), transparent);
    animation: scrollPulse 2.2s var(--ease) infinite;
  }
  @keyframes scrollPulse {
    0%,
    100% {
      opacity: 0.3;
      transform: scaleY(0.6);
      transform-origin: top;
    }
    50% {
      opacity: 1;
      transform: scaleY(1);
      transform-origin: top;
    }
  }
  @media (max-width: 640px) {
    .hero-cta .btn {
      width: 100%;
    }
    .hero-mark {
      opacity: 0.05;
    }
  }
</style>
