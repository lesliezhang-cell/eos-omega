---
import { getContent } from '../i18n/content';
import { getLangFromUrl, localizePath } from '../i18n/config';
const lang = getLangFromUrl(Astro.url);
const c = getContent(lang);
const applyHref = localizePath('/apply', lang);

interface Props {
  showHead?: boolean;
}
const { showHead = true } = Astro.props;
---

<section class="section" id="programs">
  <div class="container">
    {
      showHead && (
        <div class="section-head center">
          <p class="eyebrow" data-reveal>
            {c.programs.eyebrow}
          </p>
          <h2 data-reveal style="--reveal-delay:60ms">
            {c.programs.title}
          </h2>
          <p data-reveal style="--reveal-delay:120ms">
            {c.programs.subtitle}
          </p>
        </div>
      )
    }

    <div class="programs-grid">
      {
        c.programs.tracks.map((t, i) => (
          <article
            class:list={['card track', (t as any).featured && 'featured']}
            data-reveal
            style={`--reveal-delay:${i * 110}ms`}
          >
            {(t as any).featured && <span class="track-flag">★</span>}
            <div class="track-top">
              <span class="chip"><span class="dot" />{t.tag}</span>
              <span class="track-duration mono">{t.duration}</span>
            </div>
            <h3>{t.name}</h3>
            <p class="track-desc">{t.desc}</p>
            <ul class="track-points">
              {t.points.map((p) => (
                <li>
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 8.5l3.2 3.2L13 5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  {p}
                </li>
              ))}
            </ul>
            <a href={applyHref} class:list={['btn', (t as any).featured ? 'btn-primary' : 'btn-ghost']}>
              {c.actions.apply}
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .programs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: start;
  }
  .track {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 34px 30px;
  }
  .track.featured {
    border-color: var(--border-red);
    background: var(--surface-2);
    transform: translateY(-8px);
  }
  .track.featured:hover {
    transform: translateY(-12px);
  }
  .track-flag {
    position: absolute;
    top: 22px;
    right: 24px;
    color: var(--red-400);
  }
  .track-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 18px;
  }
  .track-duration {
    font-size: 0.8rem;
    color: var(--text-dim);
  }
  .track h3 {
    font-size: 1.5rem;
    margin-bottom: 12px;
  }
  .track-desc {
    font-size: 0.96rem;
    margin-bottom: 22px;
  }
  .track-points {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 28px;
    flex-grow: 1;
  }
  .track-points li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.92rem;
    color: var(--text-muted);
  }
  .track-points svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-top: 3px;
    color: var(--red-400);
  }
  .track .btn {
    justify-content: center;
    width: 100%;
  }
  @media (max-width: 920px) {
    .programs-grid {
      grid-template-columns: 1fr;
      max-width: 460px;
      margin-inline: auto;
    }
    .track.featured {
      transform: none;
    }
    .track.featured:hover {
      transform: translateY(-4px);
    }
  }
</style>
