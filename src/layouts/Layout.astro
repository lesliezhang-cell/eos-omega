---
import '@fontsource-variable/geist';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Background from '../components/Background.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getContent } from '../i18n/content';
import { getLangFromUrl } from '../i18n/config';

interface Props {
  title?: string;
  description?: string;
}

const url = Astro.url;
const lang = getLangFromUrl(url);
const c = getContent(lang);

const { title, description } = Astro.props;
const pageTitle = title ? `${title} · ${c.brand.full}` : `${c.brand.full} — ${c.official}`;
const pageDesc = description ?? c.hero.subtitle;

// Base-aware asset URLs + absolute canonical/OG image.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const asset = (p: string) => `${base}/${p}`;
const canonical = Astro.url.href;
const ogImage = Astro.site ? new URL(`${base}/og-card.png`, Astro.site).href : asset('og-card.png');
const ogLocale = lang === 'zh' ? 'zh_CN' : 'en_US';
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0a0a0c" />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href={asset('favicon.svg')} />
    <link rel="icon" type="image/png" sizes="512x512" href={asset('icon-512.png')} />
    <link rel="apple-touch-icon" sizes="180x180" href={asset('apple-touch-icon.png')} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:site_name" content={c.brand.full} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Background />
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <script>
      // Reveal-on-scroll — re-inits after every ClientRouter navigation.
      function initReveal() {
        const els = document.querySelectorAll<HTMLElement>('[data-reveal]');
        if (!('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        els.forEach((el) => {
          if ((el as any).__ob) return;
          (el as any).__ob = 1;
          io.observe(el);
        });
      }

      // Count-up for stat values when they enter the viewport.
      function initCounters() {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const els = document.querySelectorAll<HTMLElement>(
          '.stat-value, .pf-agg-val, .dd-stat-val, .cm-stat-val'
        );
        els.forEach((el) => {
          if ((el as any).__count) return;
          (el as any).__count = 1;
          const final = el.textContent ?? '';
          const m = final.match(/^([^0-9]*)([0-9]+(?:\.[0-9]+)?)(.*)$/);
          if (!m) return;
          const pre = m[1];
          const target = parseFloat(m[2]);
          const decimals = (m[2].split('.')[1] || '').length;
          const suf = m[3];
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                io.unobserve(el);
                const t0 = performance.now();
                const D = 1200;
                const step = (t: number) => {
                  const p = Math.min(1, (t - t0) / D);
                  const eased = 1 - Math.pow(1 - p, 3);
                  el.textContent = pre + (target * eased).toFixed(decimals) + suf;
                  if (p < 1) requestAnimationFrame(step);
                  else el.textContent = final;
                };
                requestAnimationFrame(step);
              });
            },
            { threshold: 0.5 }
          );
          io.observe(el);
        });
      }

      const initPage = () => {
        initReveal();
        initCounters();
      };
      initPage();
      document.addEventListener('astro:page-load', initPage);
    </script>
  </body>
</html>
